[2026-03-23T11:56:14.421Z] s-3b94d092-3121-44ad-a039-a4e62f7a168a qsv_sqlp: qsv_sqlp | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/Primary_Land_Use_Tax_Lot_Output_(PLUTO)_20260206.csv","sql":"\n-- Identify underbuilt residential lots (zoning capacity analysis)\n-- Filter to residential zoning (R1 through R10) with unitsres > 0\nSELECT \n  boro,\n  community_board,\n  COUNT(*) AS num_underbuilt_lots,\n  SUM(CAST(residfar AS FLOAT)) AS total_allowable_far,\n  SUM(CAST(builtfar AS FLOAT)) AS total_current_far,\n  ROUND(AVG(CAST(residfar AS FLOAT)), 2) AS avg_allowable_far,\n  ROUND(AVG(CAST(builtfar AS FLOAT)), 2) AS avg_current_far,\n  ROUND(AVG(CAST(unitsres AS FLOAT)), 0) AS avg_current_units\nFROM _t_1\nWHERE CAST(residfar AS FLOAT) > 0 \n  AND CAST(builtfar AS FLOAT) < CAST(residfar AS FLOAT)\n  AND CAST(unitsres AS FLOAT) > 0\nGROUP BY boro, community_board\nORDER BY boro, community_board\n","format":"csv","output_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/pluto_underbuilt_capacity.csv"}
