[2026-03-24T12:05:40.759Z] s-7a2ed80e-7bfe-443c-90bb-5ffd83b0dbd8 qsv_sqlp: Get 421-a expiration year distribution by borough | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  end_421a,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units,\n  boro_name\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY end_421a, boro_name\nORDER BY end_421a, boro_name"}
[2026-03-24T12:05:40.788Z] e-7a2ed80e-7bfe-443c-90bb-5ffd83b0dbd8 qsv_sqlp: ok(0.03s)
[2026-03-24T12:05:43.075Z] s-eccecf60-2d56-47a0-8391-134cc44eba2b qsv_sqlp: Get 421-a expiration timeline with condition indicators | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  end_421a,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units,\n  ROUND(AVG(ser_violation), 2) as avg_violations,\n  SUM(CASE WHEN tax_delinquency = 1 THEN 1 ELSE 0 END) as tax_delinquent\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY end_421a\nORDER BY end_421a"}
[2026-03-24T12:05:43.096Z] e-eccecf60-2d56-47a0-8391-134cc44eba2b qsv_sqlp: ok(0.02s)
[2026-03-24T12:05:50.709Z] s-8807a8b8-6f4e-4bde-be9a-46980e383bdc qsv_sqlp: Summarize 421-a expirations by time window | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  CASE \n    WHEN end_421a <= 20260101 THEN 'Already expired or expiring 2026'\n    WHEN end_421a <= 20300101 THEN '2027-2030'\n    WHEN end_421a <= 20350101 THEN '2031-2035'\n    WHEN end_421a <= 20400101 THEN '2036-2040'\n    WHEN end_421a <= 20450101 THEN '2041-2045'\n    ELSE '2046+'\n  END as expiration_window,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units,\n  SUM(CASE WHEN tax_delinquency = 1 THEN 1 ELSE 0 END) as tax_delinquent\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY expiration_window\nORDER BY expiration_window"}
[2026-03-24T12:05:50.727Z] e-8807a8b8-6f4e-4bde-be9a-46980e383bdc qsv_sqlp: ok(0.02s)
[2026-03-24T12:05:53.133Z] s-56c4eeee-54c3-46a0-be76-cbf5eff520b3 qsv_sqlp: Borough-level 421-a summary with near-term expirations | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  boro_name,\n  COUNT(*) as properties_421a,\n  SUM(res_units) as total_units,\n  MIN(end_421a) as earliest_expiry,\n  MAX(end_421a) as latest_expiry,\n  SUM(CASE WHEN end_421a <= 20300101 THEN res_units ELSE 0 END) as units_expiring_by_2030,\n  SUM(CASE WHEN end_421a <= 20350101 THEN res_units ELSE 0 END) as units_expiring_by_2035\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY boro_name\nORDER BY total_units DESC"}
[2026-03-24T12:05:53.157Z] e-56c4eeee-54c3-46a0-be76-cbf5eff520b3 qsv_sqlp: ok(0.02s)
[2026-03-24T12:08:11.115Z] s-7633558b-4f00-4c9f-b5d1-d77fea472e56 qsv_sqlp: Annual expiration counts for timeline chart | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  end_421a / 10000 as expiry_year,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY expiry_year\nORDER BY expiry_year"}
[2026-03-24T12:08:11.182Z] e-7633558b-4f00-4c9f-b5d1-d77fea472e56 qsv_sqlp: ok(0.09s)
[2026-03-24T12:08:12.851Z] s-966ad1b9-cb7d-4246-a8c0-2a1b332a5ff8 qsv_sqlp: Borough × year expiration data for dashboard | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  boro_name,\n  end_421a / 10000 as expiry_year,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY boro_name, expiry_year\nORDER BY boro_name, expiry_year"}
[2026-03-24T12:08:12.882Z] e-966ad1b9-cb7d-4246-a8c0-2a1b332a5ff8 qsv_sqlp: ok(0.03s)
[2026-03-24T12:08:14.659Z] s-f9725628-6f08-44de-938a-17cd016a0606 qsv_sqlp: Start year distribution for program era analysis | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_bbl_analysis_2025-05-13.csv","sql":"SELECT \n  start_421a / 10000 as start_year,\n  COUNT(*) as properties,\n  SUM(res_units) as total_units\nFROM _t_1\nWHERE prog_421a = 1\nGROUP BY start_year\nORDER BY start_year"}
[2026-03-24T12:08:14.676Z] e-f9725628-6f08-44de-938a-17cd016a0606 qsv_sqlp: ok(0.02s)
[2026-03-24T12:21:29.551Z] s-edde6fae-cdd1-4d95-b0aa-34f4fd658a47 qsv_sqlp: Borough-level public land summary from actual PLUTO data | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/public_land_inventory.csv","sql":"SELECT \n  borough_name,\n  COUNT(*) as parcels,\n  ROUND(SUM(lotarea) / 43560.0, 1) as total_acres,\n  SUM(unitsres) as existing_units,\n  ROUND(SUM(unused_residfar_sqft) / 800.0, 0) as potential_new_units,\n  SUM(CASE WHEN pfirm15_flag = 1 THEN 1 ELSE 0 END) as flood_zone_parcels,\n  ROUND(AVG(lotarea), 0) as avg_lot_sqft\nFROM _t_1\nGROUP BY borough_name\nORDER BY total_acres DESC"}
[2026-03-24T12:21:29.747Z] e-edde6fae-cdd1-4d95-b0aa-34f4fd658a47 qsv_sqlp: ok(0.22s)
[2026-03-24T12:21:32.879Z] s-50ea9ae9-372b-40c1-ba49-e02a7881e059 qsv_sqlp: Top zoning districts by development potential | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/public_land_inventory.csv","sql":"SELECT \n  borough_name,\n  zonedist1,\n  COUNT(*) as parcels,\n  ROUND(SUM(lotarea) / 43560.0, 2) as acres,\n  ROUND(SUM(unused_residfar_sqft) / 800.0, 0) as potential_units\nFROM _t_1\nWHERE unused_residfar_sqft > 0\nGROUP BY borough_name, zonedist1\nORDER BY potential_units DESC\nLIMIT 30"}
