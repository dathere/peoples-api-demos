[2026-03-24T12:22:04.715Z] s-8a0c3797-690f-435c-add7-250fda87b97e qsv_sqlp: City-owned residentially-zoned parcels with development capacity | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/Primary_Land_Use_Tax_Lot_Output_(PLUTO)_20260206.csv","sql":"SELECT \n  borough,\n  COUNT(*) as parcels,\n  ROUND(SUM(CAST(REPLACE(lotarea, ',', '') AS DOUBLE)) / 43560.0, 1) as total_acres,\n  ROUND(SUM(CASE WHEN CAST(REPLACE(residfar, ',', '') AS DOUBLE) > 0 \n    THEN (CAST(REPLACE(residfar, ',', '') AS DOUBLE) * CAST(REPLACE(lotarea, ',', '') AS DOUBLE)) - CAST(REPLACE(bldgarea, ',', '') AS DOUBLE)\n    ELSE 0 END) / 800.0, 0) as potential_units,\n  SUM(CASE WHEN pfirm15_flag = '1' THEN 1 ELSE 0 END) as flood_zone,\n  ROUND(AVG(CAST(REPLACE(lotarea, ',', '') AS DOUBLE)), 0) as avg_lot_sqft\nFROM _t_1\nWHERE ownertype = 'C'\n  AND has_residential_zoning = '1'\nGROUP BY borough\nORDER BY potential_units DESC","ignore_errors":true,"infer_len":"50000"}
