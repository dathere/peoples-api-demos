[2026-03-23T11:55:21.533Z] s-9973994d-b997-49bd-bd49-79ad4afd64d4 qsv_sqlp: qsv_sqlp | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/HousingDB_post2010.csv","sql":"\nSELECT \n  PermitYear AS year,\n  Job_Type,\n  Boro,\n  COUNT(*) AS num_jobs,\n  COALESCE(SUM(CAST(ClassANet AS FLOAT)), 0) AS net_residential_units,\n  COALESCE(SUM(CAST(ClassAProp AS FLOAT)), 0) AS proposed_residential_units\nFROM (SELECT * FROM read_csv('HousingDB_post2010.csv'))\nWHERE PermitYear >= 2010 AND PermitYear <= 2026\nGROUP BY PermitYear, Job_Type, Boro\nORDER BY year DESC, Job_Type, Boro\n","format":"csv","output_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/housing_supply_by_year_type.csv"}
