[2026-03-23T11:55:43.997Z] s-b5d93392-ad99-4e1d-86a3-3b364b51a196 qsv_sqlp: qsv_sqlp | args: {"input_file":"/Users/joelnatividad/Downloads/policy-agent_demo-NYC/FC_SHD_subsidy_analysis_2025-05-13.csv","sql":"\n-- Subsidy expiration risk analysis: units at risk by program\nSELECT \n  subsidy_name,\n  COUNT(*) AS num_properties,\n  SUM(CAST(tot_units AS FLOAT)) AS total_units,\n  MIN(CAST(end_date AS DATE)) AS earliest_expiration,\n  MAX(CAST(end_date AS DATE)) AS latest_expiration,\n  SUM(CASE \n    WHEN CAST(end_date AS DATE) <= CAST('2026-03-23' AS DATE) THEN CAST(tot_units AS FLOAT) \n    ELSE 0 \n  END) AS units_already_expired,\n  SUM(CASE \n    WHEN CAST(end_date AS DATE) > CAST('2026-03-23' AS DATE) AND CAST(end_date AS DATE) <= DATE_ADD(CAST('2026-03-23' AS DATE), INTERVAL 5 YEAR) THEN CAST(tot_units AS FLOAT)\n    ELSE 0\n  END) AS units_expiring_5yrs,\n  SUM(CASE \n    WHEN CAST(end_date AS DATE) > CAST('2026-03-23' AS DATE) AND CAST(end_date AS DATE) <= DATE_ADD(CAST('2026-03-23' AS DATE), INTERVAL 10 YEAR) THEN CAST(tot_units AS FLOAT)\n    ELSE 0\n  END) AS units_expiring_10yrs\nFROM _t_1…[truncated]
